[user]
    name = Dolugen
    email = dolugen@gmail.com
[alias]
    ci = commit -v
    co = checkout
    st = status -s
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --
    lo = log --oneline
    br = branch
    diffc = diff --cached
[color]
    status = always
    diff = always
    branch = always
[core]
    editor = emacs -nw
[push]
    default = current
[merge]
	ff = false