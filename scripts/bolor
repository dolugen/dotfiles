#!/usr/bin/env python
import sys
import argparse
from urllib2 import urlopen

try:
    from bs4 import BeautifulSoup as BS4
except ImportError:
    exit("Missing dependency: BeautifulSoup4")

parser = argparse.ArgumentParser(
    description='Look up words from Bolor dictionary.',
    prog='bolor')
parser.add_argument('-i', dest='input', help='search word')
parser.add_argument('-p', dest='prompt', action='store_true', help='start interactive shell')

bolor_url = "http://www.bolor-toli.com/dictionary/word?"
data = "selected_lang=4-1&search={}"
word_types = [
    "noun",
    "verb",
    "adjective",
    "adverb",
    "other",
]

def pretty_print(line):
    " Colorful output to stdout "
    line += "(Reset)\n"

    line = line.replace("(Gray)", "\033[0;90m")
    line = line.replace("(Reset)", "\033[0m")

    sys.stdout.write(line)
    sys.stdout.flush()


def display_result(result):
    if not result:
        print 'Not Found'
        return

    for word_type in word_types:
        if len(result.get(word_type, [])) > 0:
            pretty_print("(Gray)%s" % word_type)

        for word in result.get(word_type, []):
            pretty_print("  %s" % word)


def bolor_query(word):

    soup = BS4(urlopen(bolor_url, data.format(word)).read())

    result = {}
    rows = soup.select("#exact_translations table tr")

    if not rows:
        return None

    for row in rows:
        # Skip non-result rows
        if not row.select(".link-string"):
            continue

        word_type = row.select("td")[3].select("span")[1].text or "[other]"
        word_type = word_type.split("]")[0][1:].lower()  # "[noun][comp.]" -> "noun"
        word = row.select(".link-string")[0].text

        result.setdefault(word_type, []).append(word)

    return result


if __name__ == "__main__":
    args = parser.parse_args()

    if not args.input and not args.prompt:
        parser.print_help()
        exit()

    while args.prompt:
        query = raw_input('bolor> ')

        if query == "quit!":
            exit()

        result = bolor_query(query)
        display_result(result)

    result = bolor_query(args.input)
    display_result(result)
